generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Non-pooled URL (Neon “direct” connection). Required for reliable interactive $transaction with many hosts.
  directUrl = env("DIRECT_URL")
}

enum TournamentStatus {
  DRAFT
  BRACKET_READY
  IN_PROGRESS
  COMPLETED
}

enum TournamentGameType {
  DEFAULT
  POOL
}

enum PoolStatKind {
  MADE
  MISSED
  FOUL
}

model Player {
  id             String          @id @default(cuid())
  name           String
  avatarUrl      String?
  bio            String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  teamPlayers    TeamPlayer[]
  poolStatEvents PoolStatEvent[]
}

model Tournament {
  id             String             @id @default(cuid())
  slug           String             @unique
  name           String
  playersPerTeam Int                @default(2)
  status         TournamentStatus   @default(DRAFT)
  gameType       TournamentGameType @default(DEFAULT)
  /** First team to this many sunk balls (MADE) wins the match (pool only). */
  poolRaceTo     Int                @default(5)
  logoUrl        String?
  trophyImageUrl String?
  theme          Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  teams          Team[]
  matches        Match[]
}

model Team {
  id            String       @id @default(cuid())
  tournamentId  String
  name          String
  seedOrder     Int?
  tournament    Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamPlayers   TeamPlayer[]
  matchesAsA    Match[]      @relation("MatchTeamA")
  matchesAsB    Match[]      @relation("MatchTeamB")
  wins          Match[]      @relation("MatchWinner")
  proposedWins  Match[]      @relation("MatchProposedWinner")

  @@index([tournamentId])
}

model TeamPlayer {
  id        String @id @default(cuid())
  teamId    String
  playerId  String
  slotIndex Int
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, slotIndex])
  @@unique([teamId, playerId])
}

model Match {
  id                     String     @id @default(cuid())
  tournamentId           String
  roundIndex             Int
  positionInRound        Int
  teamAId                String?
  teamBId                String?
  winnerTeamId           String?
  isLive                 Boolean    @default(false)
  /** Override tournament.poolRaceTo when set (pool). */
  poolRaceToOverride     Int?
  proposedWinnerTeamId   String?
  tournament             Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamA                  Team?      @relation("MatchTeamA", fields: [teamAId], references: [id])
  teamB                  Team?      @relation("MatchTeamB", fields: [teamBId], references: [id])
  winner                 Team?      @relation("MatchWinner", fields: [winnerTeamId], references: [id])
  proposedWinner         Team?      @relation("MatchProposedWinner", fields: [proposedWinnerTeamId], references: [id])
  poolStatEvents         PoolStatEvent[]

  @@unique([tournamentId, roundIndex, positionInRound])
  @@index([tournamentId])
}

model PoolStatEvent {
  id        String       @id @default(cuid())
  matchId   String
  playerId  String
  kind      PoolStatKind
  sequence  Int
  createdAt DateTime     @default(now())
  match     Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, sequence])
  @@index([matchId])
}
