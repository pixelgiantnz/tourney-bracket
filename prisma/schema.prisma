generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Non-pooled URL (Neon “direct” connection). Required for reliable interactive $transaction with many hosts.
  directUrl = env("DIRECT_URL")
}

enum TournamentStatus {
  DRAFT
  BRACKET_READY
  IN_PROGRESS
  COMPLETED
}

model Player {
  id          String       @id @default(cuid())
  name        String
  avatarUrl   String?
  bio         String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  teamPlayers TeamPlayer[]
}

model Tournament {
  id             String            @id @default(cuid())
  slug           String            @unique
  name           String
  playersPerTeam Int               @default(2)
  status         TournamentStatus  @default(DRAFT)
  logoUrl        String?
  trophyImageUrl String?
  theme          Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  teams          Team[]
  matches        Match[]
}

model Team {
  id           String       @id @default(cuid())
  tournamentId String
  name         String
  seedOrder    Int?
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamPlayers  TeamPlayer[]
  matchesAsA   Match[]      @relation("MatchTeamA")
  matchesAsB   Match[]      @relation("MatchTeamB")
  wins         Match[]      @relation("MatchWinner")

  @@index([tournamentId])
}

model TeamPlayer {
  id        String @id @default(cuid())
  teamId    String
  playerId  String
  slotIndex Int
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, slotIndex])
  @@unique([teamId, playerId])
}

model Match {
  id              String     @id @default(cuid())
  tournamentId    String
  roundIndex      Int
  positionInRound Int
  teamAId         String?
  teamBId         String?
  winnerTeamId    String?
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamA           Team?      @relation("MatchTeamA", fields: [teamAId], references: [id])
  teamB           Team?      @relation("MatchTeamB", fields: [teamBId], references: [id])
  winner          Team?      @relation("MatchWinner", fields: [winnerTeamId], references: [id])

  @@unique([tournamentId, roundIndex, positionInRound])
  @@index([tournamentId])
}
