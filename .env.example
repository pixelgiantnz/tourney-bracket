# Copy to .env and fill before local dev or Vercel env settings.

# Pooled URL (Neon) — good for general queries
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct / non-pooled — same DB; from Neon dashboard “Connection details” → direct. Needed for Prisma interactive transactions.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Vercel Blob — create a store in the Vercel project and paste the read/write token.
BLOB_READ_WRITE_TOKEN=""

# Session signing (use a long random string, e.g. openssl rand -hex 32)
SESSION_SECRET=""

SITE_PASSWORD=""
ADMIN_PASSWORD=""

# Public URL of the app (e.g. https://your-project.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
